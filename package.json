{
  "name": "specbook",
  "version": "0.1.0",
  "description": "Static site generator for software project specifications.",
  "type": "module",
  "license": "MIT",
  "keywords": ["static-site-generator", "specification", "spec", "documentation", "react", "vite", "tailwind"],
  "repository": {
    "type": "git",
    "url": "https://github.com/carl-ee/specbook"
  },
  "homepage": "https://github.com/carl-ee/specbook#readme",
  "bugs": {
    "url": "https://github.com/carl-ee/specbook/issues"
  },
  "bin": {
    "specbook": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts examples/taskflow",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm test && pnpm build",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "jiti": "^2.6.1",
    "mermaid-isomorphic": "^3.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yaml": "^2.8.4",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
